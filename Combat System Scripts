-- Combat
local combat = {}

local ReplicatedStorage = game:GetService("ReplicatedStorage")

local combat = ReplicatedStorage:WaitForChild("Combat")
local animations = combat:WaitForChild("Animations")
local remotes = combat:WaitForChild("Remotes")
local sfx = combat:WaitForChild("SFX")
local modules = combat:WaitForChild("Modules")
local configuration = combat:WaitForChild("Configuration")

local hit = require(script.Parent.Hit)
local block = require(script.Parent.Block)
local ragdoll = require(modules.Ragdoll)


remotes.Combat.OnServerEvent:Connect(function(player, data)
	if data.action == "hit" then
		if next(data.hits) then
			for _, v in pairs(data.hits) do
				hit.hit(player.Character, v, configuration:GetAttribute("M1_Damage"), configuration:GetAttribute("Stun_Time"), data.combo, data.state)
			end
		else
			if data.combo == 4 then
				local stun = Instance.new("BoolValue", player.Character)
				stun.Name = "Stun"
				task.delay(configuration:GetAttribute("Stun_Time"), function()
					stun:Destroy()
				end)
			end
		end
		
	elseif data.action == "block" then
		block.Start(player.Character)
		
	elseif data.action == "unblock" then
		block.Stop(player.Character)
		
	elseif data.action == "evasive" then
		ragdoll.Stop(player.Character)
	end
end)

return combat
-- Hit 
local hit = {}

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")

local combat = ReplicatedStorage:WaitForChild("Combat")
local animations = combat:WaitForChild("Animations")
local sfx = combat:WaitForChild("SFX")
local fxstorage = combat:WaitForChild("Fx")
local configuration = combat:WaitForChild("Configuration")

local modules = combat:WaitForChild("Modules")
local ragdoll = require(modules.Ragdoll)


function hit.hit(player, v, damage, stuntime, combo, state)
	if v:FindFirstChild("Iframe") then return end
	
	if v:FindFirstChild("Block") then
		if (player.HumanoidRootPart.Position - v.HumanoidRootPart.Position).Unit:Dot(v.HumanoidRootPart.CFrame.LookVector) > 0.5 then
			local load = v.Humanoid:LoadAnimation(animations.Block.Hit:FindFirstChild(math.random(1, #animations.Block.Hit:GetChildren())))
			load.Priority = Enum.AnimationPriority.Action4
			load:Play()

			local sfxclone = sfx.Block:Clone()
			sfxclone.Parent = v.HumanoidRootPart
			sfxclone:Play()
			task.delay(sfxclone.TimeLength, function()
				sfxclone:Destroy()
			end)

			if combo == 4 then
				local stun = Instance.new("BoolValue", player)
				stun.Name = "Stun"
				task.delay(stuntime, function()
					stun:Destroy()
				end)
			end

			return
		end
	end
	
	if state == "land" or state == "air" then
		v.Humanoid:TakeDamage(damage)

		local stun = Instance.new("BoolValue", v)
		stun.Name = "Stun"

		local sfxclone = sfx.Hit:Clone()
		sfxclone.Parent = v.HumanoidRootPart
		sfxclone:Play()
		task.delay(sfxclone.TimeLength, function()
			sfxclone:Destroy()
		end)

		local fx = fxstorage.Hit:Clone()
		fx.Parent = workspace.Fx
		fx.CFrame = v.HumanoidRootPart.CFrame
		task.wait(.01)
		for _, v in pairs(fx:GetDescendants()) do
			if v:IsA("ParticleEmitter") then
				v:Emit(10)
			end
		end
		task.delay(2, function()
			fx:Destroy()
		end)

		local dmgindicator = script.DamageIndicator:Clone()
		dmgindicator.Parent = v
		dmgindicator.ExtentsOffset = Vector3.new((math.random(-10, 10) / 10), .5, 0)
		dmgindicator.Count.Text = "- "..damage
		TweenService:Create(dmgindicator, TweenInfo.new(stuntime), {ExtentsOffset = Vector3.new(dmgindicator.ExtentsOffset.X, 1, 0)}):Play()

		local highlight = Instance.new("Highlight", v)
		highlight.OutlineTransparency = 1
		highlight.FillTransparency = 0
		highlight.FillColor = Color3.new(1, 0, 0)
		highlight.DepthMode = Enum.HighlightDepthMode.Occluded
		TweenService:Create(highlight, TweenInfo.new(stuntime), {FillTransparency = 1}):Play()

		if combo == 4 then
			if state == "land" then
				local velocity = Instance.new("BodyVelocity", v.HumanoidRootPart)
				velocity.MaxForce = Vector3.new(1, 1, 1) * math.huge
				velocity.Velocity = player.HumanoidRootPart.CFrame.LookVector * 35
				task.delay(.4, function()
					velocity:Destroy()
				end)
				
				if configuration:GetAttribute("Ragdoll") == true then
					task.spawn(function()
						ragdoll.Start(v, configuration:GetAttribute("Ragdoll_Duration"))
					end)
				else
					local load = v.Humanoid:LoadAnimation(animations.Dash.Back)
					load.Priority = Enum.AnimationPriority.Action4
					load:Play()
					load:AdjustSpeed(1.5)
				end
				
			elseif state == "air" then
				if configuration:GetAttribute("Ragdoll") == true then
					task.spawn(function()
						ragdoll.Start(v, configuration:GetAttribute("Ragdoll_Duration"))
					end)
				end

				local velocity = Instance.new("BodyVelocity", v.HumanoidRootPart)
				velocity.MaxForce = Vector3.new(1, 1, 1) * math.huge
				velocity.Velocity = player.HumanoidRootPart.CFrame.LookVector * 10 + Vector3.new(0, 35, 0)
				task.delay(.15, function()
					velocity:Destroy()
				end)
			end
		else
			local load = v.Humanoid:LoadAnimation(animations.Hits:FindFirstChild(math.random(1, #animations.Hits:GetChildren())))
			load.Priority = Enum.AnimationPriority.Action4
			load:Play()
		end

		task.delay(stuntime, function()
			stun:Destroy()
			highlight:Destroy()
			dmgindicator:Destroy()
		end)
	else
		v.Humanoid:TakeDamage(damage)

		local stun = Instance.new("BoolValue", v)
		stun.Name = "Stun"

		local sfxclone = sfx.Hit:Clone()
		sfxclone.Parent = v.HumanoidRootPart
		sfxclone:Play()
		task.delay(sfxclone.TimeLength, function()
			sfxclone:Destroy()
		end)

		local fx = fxstorage.Hit:Clone()
		fx.Parent = workspace.Fx
		fx.CFrame = v.HumanoidRootPart.CFrame
		task.wait(.01)
		for _, v in pairs(fx:GetDescendants()) do
			if v:IsA("ParticleEmitter") then
				v:Emit(10)
			end
		end
		task.delay(2, function()
			fx:Destroy()
		end)

		local dmgindicator = script.DamageIndicator:Clone()
		dmgindicator.Parent = v
		dmgindicator.ExtentsOffset = Vector3.new((math.random(-10, 10) / 10), .5, 0)
		dmgindicator.Count.Text = "- "..damage
		TweenService:Create(dmgindicator, TweenInfo.new(stuntime), {ExtentsOffset = Vector3.new(dmgindicator.ExtentsOffset.X, 1, 0)}):Play()

		local highlight = Instance.new("Highlight", v)
		highlight.OutlineTransparency = 1
		highlight.FillTransparency = 0
		highlight.FillColor = Color3.new(1, 0, 0)
		highlight.DepthMode = Enum.HighlightDepthMode.Occluded
		TweenService:Create(highlight, TweenInfo.new(stuntime), {FillTransparency = 1}):Play()

		if combo == 4 then
			if configuration:GetAttribute("Ragdoll") == true then
				task.spawn(function()
					ragdoll.Start(v, configuration:GetAttribute("Ragdoll_Duration"))
				end)
			else
				local load = v.Humanoid:LoadAnimation(animations.Dash.Back)
				load.Priority = Enum.AnimationPriority.Action4
				load:Play()
				load:AdjustSpeed(1.5)
			end
		else
			local load = v.Humanoid:LoadAnimation(animations.Hits:FindFirstChild(math.random(1, #animations.Hits:GetChildren())))
			load.Priority = Enum.AnimationPriority.Action4
			load:Play()
		end

		task.delay(stuntime, function()
			stun:Destroy()
			highlight:Destroy()
			dmgindicator:Destroy()
		end)
	end
end

return hit
-- Ragdoll
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")


local Sockets = {}
local Colliders = {}
local Attachments = {}

local Ragdoll = {}

local Params = RaycastParams.new()
Params.FilterType = Enum.RaycastFilterType.Exclude
Params.FilterDescendantsInstances = {workspace, workspace}

function CreateCollider(Item : BasePart, Character : Model)
	local Collider = Instance.new("Part")
	Collider.Size = Item.Size / 2
	Collider.Transparency = 1

	local NoCollisionConstraint = Instance.new("NoCollisionConstraint")
	NoCollisionConstraint.Part0 = Item
	NoCollisionConstraint.Part1 = Collider
	NoCollisionConstraint.Parent = Collider

	local Weld = Instance.new("Weld")
	Weld.Part0 = Item
	Weld.Part1 = Collider

	Weld.Parent = Collider
	Collider.Parent = Item

	Colliders[Character][Item] = Collider
end

function Ragdoll.Start(Character : Model, Duration : number)
	if Character == nil then 
		return 
	end

	local Humanoid : Humanoid = Character:WaitForChild("Humanoid")
	local RootPart = Humanoid.RootPart

	if Character:GetAttribute("Ragdolled") or Humanoid.Health < 1 then
		return
	end

	local Impact : RBXScriptConnection

	Sockets[Character] = {}
	Colliders[Character] = {}
	Attachments[Character] = {}

	Character:SetAttribute("Ragdolled", true)

	local iframe = Instance.new("BoolValue", Character)
	iframe.Name = "Iframe"
	
	local stun = Instance.new("BoolValue", Character)
	stun.Name = "Stun"
	
	Humanoid.RequiresNeck = false
	Humanoid.PlatformStand = true
	Humanoid.AutoRotate = false

	for _, Item in ipairs(Character:GetDescendants()) do
		if Item:IsDescendantOf(RootPart) then 
			continue
		end

		if Item:FindFirstAncestorWhichIsA("Model") ~= Character then
			continue
		end

		if Item:IsA("Motor6D") then
			CreateCollider(Item.Part1, Character)

			Item.Enabled = false

			local Attachment0 = Instance.new("Attachment")
			Attachment0.CFrame = Item.C0
			Attachment0.Parent = Item.Part0

			local Attachment1 = Instance.new("Attachment")
			Attachment1.CFrame = Item.C1
			Attachment1.Parent = Item.Part1

			local Socket = Instance.new("BallSocketConstraint")
			Socket.Attachment0 = Attachment0
			Socket.Attachment1 = Attachment1

			Socket.LimitsEnabled = true
			Socket.TwistLimitsEnabled = true

			Socket.Parent = Item.Parent
			Sockets[Character][Item] = Socket

			table.insert(Attachments[Character], Attachment0)
			table.insert(Attachments[Character], Attachment1)
		end
	end

	if Duration ~= nil then
		task.delay(Duration, function()
			Ragdoll.Stop(Character)
		end)
	end
end

function Ragdoll.Stop(Character : Model)
	if Character:FindFirstChild("NoUnragdoll") then return end
	if Character:FindFirstChild("Downed") then return end
	
	if Character == nil then
		return
	end

	if not Character:GetAttribute("Ragdolled") then
		return
	end

	local Humanoid : Humanoid = Character:WaitForChild("Humanoid")
	local RootPart = Humanoid.RootPart

	

	Humanoid.RequiresNeck = true
	Humanoid.PlatformStand = false
	Humanoid.AutoRotate = true

	Character:SetAttribute("Ragdolled", false)
	
	if Character:FindFirstChild("Stun") then
		Character.Stun:Destroy()
	end
	
	task.delay(.25, function()
		if Character:FindFirstChild("Iframe") then
			Character.Iframe:Destroy()
		end
	end)

	RootPart.CFrame = CFrame.lookAt(Vector3.zero, RootPart.CFrame.RightVector:Cross(-Vector3.yAxis)) + RootPart.Position

	

	for Limb, Collider in pairs(Colliders[Character]) do
		for _, Attachment in pairs(Limb:GetChildren()) do
			if Attachment:IsA("Attachment") then
				Attachment:Destroy()
			end
		end

		Collider:Destroy()
	end

	for _, Attachment in pairs(Attachments[Character]) do
		Attachment:Destroy()
	end

	for Joint, Socket in pairs(Sockets[Character]) do
		Joint.Enabled = true
		Socket:Destroy()
	end

	table.clear(Sockets[Character])
	table.clear(Colliders[Character])
	table.clear(Attachments[Character])

	Sockets[Character] = nil
	Colliders[Character] = nil
	Attachments[Character] = nil
end

return Ragdoll
