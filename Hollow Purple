game.ReplicatedStorage.Remotes.Gojo.Function.OnClientInvoke = function(Hitbox)
	task.wait()
	if Hitbox.Value then
		--// Add hollow vfx
		local HollowPurple = AssetsFolder.Gojo["Hollow Purple [Rework]"]:Clone()
		HollowPurple.Parent = workspace.PlayerVFX
		HollowPurple.CFrame = Hitbox.Value.CFrame
		Debris:AddItem(HollowPurple, 5)

		--// Rocks effects
		local CHARACTERS = {}
		for _, player in pairs(game.Players:GetPlayers()) do
			CHARACTERS = player.Character
		end

		local params = RaycastParams.new()
		params.FilterType = Enum.RaycastFilterType.Exclude
		params.FilterDescendantsInstances = {CHARACTERS, workspace.PlayerVFX}

		local function AddRock()
			local OriginPos = {
				[1] = Hitbox.Value.CFrame * CFrame.new(math.random(90, 110) / 10, 6, 0),
				[2] = Hitbox.Value.CFrame * CFrame.new(-math.random(90, 110) / 10, 5, 0)
			}

			local FloatRockRay = workspace:Raycast(Hitbox.Value.Position, Vector3.new(0, -10, 0), params)
			local random = math.random(1, 100) / 100
			if FloatRockRay and random >= .30 then
				DebrisModule.Rocks(CFrame.new(FloatRockRay.Position), 1, FloatRockRay.Instance.Color, FloatRockRay.Instance.Material, true)
			end

			for i = 1, 2 do
				local result = workspace:Raycast(OriginPos[i].Position, Vector3.new(0, -15, 0), params)
				if result then
					local rockEffect = Instance.new("Part")
					rockEffect.Parent = workspace.PlayerVFX
					rockEffect.Anchored = true
					rockEffect.CanCollide = false
					rockEffect.Transparency = result.Instance.Transparency
					rockEffect.Color = result.Instance.Color
					rockEffect.Material = result.Instance.Material
					rockEffect.Name = "RockEffect"
					rockEffect.CanQuery = false

					local RN = Random.new()
					local Size = RN:NextNumber(3, 10)
					rockEffect.Size = Vector3.new(
						Size, Size * .5, Size * 2
					)

					rockEffect.Position = result.Position - Vector3.new(0, 5, 0)
					rockEffect.CFrame *= CFrame.Angles(math.rad(math.random(10, 45)), math.rad(math.random(0, 360)), math.rad(math.random(0, 360)))

					TS:Create(rockEffect,
						TweenInfo.new(.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
						{Position = rockEffect.Position + Vector3.new(0, 3, 0)}
					):Play()

					task.delay(10, function()
						TS:Create(
							rockEffect,
							TweenInfo.new(2, Enum.EasingStyle.Linear, Enum.EasingDirection.In),
							{Position = rockEffect.Position - Vector3.new(0, 6, 0)}
						):Play()
					end)

					Debris:AddItem(rockEffect, 15)
				end
			end
		end

		--// Loop
		spawn(function()
			local last = nil
			while HollowPurple.Parent ~= nil and Hitbox.Value.Parent ~= nil do
				task.wait()
				TS:Create(HollowPurple,
					TweenInfo.new(.055, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut),
					{CFrame = Hitbox.Value.CFrame}
				):Play()

				if last == Hitbox.Value.CFrame then
					AddRock()
				else
					last = Hitbox.Value.CFrame
				end
			end
		end)
	end
end

